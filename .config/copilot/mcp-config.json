{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_MCP_PAT}"
      }
    },
    "markitdown-mcp": {
      "type": "local",
      "command": "markitdown-mcp",
      "args": []
    },
    "deepwiki-mcp": {
      "type": "http",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "ddg-search": {
      "type": "local",
      "command": "uvx",
      "args": ["duckduckgo-mcp-server"]
    },
    "fetch": {
      "type": "local",
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    }
  }
}
