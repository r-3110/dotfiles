{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "baseBranchPatterns": ["renovate-pr"],
  "timezone": "Asia/Tokyo",
  "description": "Run on weekdays (Mon-Fri)",
  "schedule": ["* * * * 1-5"],
  "nix": {
    "enabled": true
  },
  "ignoreDeps": ["nixpkgs"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "automerge": true
    },
    {
      "matchManagers": ["nix"],
      "automerge": true
    }
  ]
}
