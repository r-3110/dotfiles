{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "baseBranchPatterns": ["renovate-pr"],
  "timezone": "Asia/Tokyo",
  "description": "Run on weekdays (Mon-Fri)",
  "schedule": ["* * * * 1-5"],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "rebaseWhen": "behind-base-branch",
    "description": "Run every 2 days before 8am",
    "schedule": ["before 8am every 2 day"]
  },
  "ignoreDeps": ["nixpkgs"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "automerge": true
    },
    {
      "matchManagers": ["nix"],
      "automerge": true
    },
    {
      "matchManagers": ["mise"],
      "matchPackageNames": ["python"],
      "enabled": false
    }
  ]
}
